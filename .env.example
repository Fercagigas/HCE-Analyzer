
# ================================
# CONFIGURACIÓN DE API KEYS
# ================================

# Anthropic API Key (Requerido para Agente Médico y RAG)
# Obtén tu API key en: https://console.anthropic.com/
# Usado por: Medical Agent, RAG Service, Unified Chat
# Formato: sk-ant-api03-...
# Modelos soportados: Claude Haiku 4.5, Claude Sonnet 4.5, Claude Opus 4
ANTHROPIC_API_KEY=tu_api_key_de_anthropic_aqui

# Supabase Configuration (Requerido)
# Obtén estas credenciales en: https://supabase.com/dashboard
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_supabase_anon_key_aqui

# Hugging Face API Key (Opcional)
# Obtén tu API key en: https://huggingface.co/settings/tokens
HUGGINFACEHUB_API_TOKEN=tu_huggingface_api_token_aqui

# ================================
# CONFIGURACIÓN DE DESARROLLO
# ================================

# Modo Debug (Opcional)
DEBUG=False

# Modo Desarrollo (Opcional)
DEVELOPMENT_MODE=False

# ================================
# CONFIGURACIÓN AVANZADA (Opcional)
# ================================

# Directorio de datos personalizado
# DATA_DIR=./custom_data

# Configuración de logging
# LOG_LEVEL=INFO

# ================================
# CONFIGURACIÓN DE LÍMITES (Opcional)
# ================================

# Límites de uso diario
# DAILY_ANALYSES_LIMIT=15
# DAILY_RAG_QUERIES_LIMIT=50
# MAX_FILE_UPLOADS_PER_DAY=10

# Límites de archivos
# MAX_FILE_SIZE_MB=50
# MAX_SESSION_DURATION_HOURS=8

# ================================
# CONFIGURACIÓN DE RAG (Claude API)
# ================================
# El sistema RAG usa Claude API (Anthropic) para consultas de documentos clínicos
# y guías hospitalarias.

# Modelo primario para RAG (Claude)
# RAG_MODEL=claude-haiku-4-5-20251001

# Fallback chain para RAG (Claude)
# PRIMARY_MODEL=claude-haiku-4-5-20251001
# SECONDARY_MODEL=claude-sonnet-4-5-20250929
# TERTIARY_MODEL=claude-opus-4-20250514
# FALLBACK_MODEL=claude-haiku-4-5-20251001

# Configuración de RAG API
# RAG_MAX_TOKENS=4000
# RAG_TEMPERATURE=0.1
# RAG_API_RETRY_ATTEMPTS=3
# RAG_API_RETRY_DELAY=2.0
# RAG_API_TIMEOUT_SECONDS=60

# Modelo de embeddings (local)
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ================================
# CONFIGURACIÓN DE CLAUDE AGENT (Claude API)
# ================================
# El agente médico usa Claude API (Anthropic) para análisis de datos
# MIMIC-IV-ED y consultas médicas. Es independiente del sistema RAG.
# 
# IMPORTANTE: Tanto RAG como Agent usan Claude API (Anthropic)

# Modelos Claude para el agente médico (fallback chain)
# El agente intentará usar los modelos en orden: Primary -> Secondary -> Tertiary
# 
# Primary: Claude Haiku 4.5 (más rápido y económico, ideal para consultas simples)
# PRIMARY_CLAUDE_MODEL=claude-haiku-4-5-20251001
# PRIMARY_CLAUDE_MODEL_VERSION=claude-haiku-4-5-20251001
#
# Secondary: Claude Sonnet 4.5 (rendimiento balanceado, para consultas complejas)
# SECONDARY_CLAUDE_MODEL=claude-sonnet-4-5
# SECONDARY_CLAUDE_MODEL_VERSION=claude-sonnet-4-5-20250929
#
# Tertiary: Claude Opus 4 (máxima capacidad, para análisis avanzados)
# TERTIARY_CLAUDE_MODEL=claude-opus-4-0
# TERTIARY_CLAUDE_MODEL_VERSION=claude-opus-4-20250514

# Configuración de Claude API
# Máximo de tokens en la respuesta (4096 recomendado para respuestas detalladas)
# CLAUDE_MAX_TOKENS=4096
# 
# Temperatura (0.1 = más determinista, 1.0 = más creativo)
# CLAUDE_TEMPERATURE=0.1
#
# Timeout en segundos para llamadas API
# CLAUDE_TIMEOUT_SECONDS=30

# Configuración de reintentos para Claude
# Número máximo de reintentos en caso de error
# CLAUDE_MAX_RETRIES=3
#
# Delay inicial entre reintentos (en segundos)
# CLAUDE_RETRY_DELAY=2.0
#
# Multiplicador para backoff exponencial (2.0 = 2s, 4s, 8s...)
# CLAUDE_BACKOFF_MULTIPLIER=2.0

# Configuración del agente Claude
# Rol del agente (define su comportamiento y expertise)
# CLAUDE_AGENT_ROLE=Asistente Médico Especializado
#
# Máximo de iteraciones del agente (ciclos de razonamiento)
# CLAUDE_MAX_ITERATIONS=15
#
# Modo verbose (muestra logs detallados del proceso)
# CLAUDE_VERBOSE=True

# ================================
# CONFIGURACIÓN DE VISUALIZACIÓN (Opcional)
# ================================
# El sistema de visualización usa Claude Sonnet 4.5 para generar
# código Python de visualizaciones médicas con Plotly

# Modelo para visualización (Claude Sonnet 4.5)
# VISUALIZATION_MODEL=claude-sonnet-4-5
# VISUALIZATION_MODEL_VERSION=claude-sonnet-4-5-20250929

# Configuración de rendimiento
# VISUALIZATION_MAX_TOKENS=8192
# VISUALIZATION_TEMPERATURE=0.1
# VISUALIZATION_TIMEOUT_SECONDS=45

# Configuración de reintentos (optimizado para rendimiento)
# VISUALIZATION_MAX_RETRIES=3
# VISUALIZATION_RETRY_DELAY=1.5

# Configuración de generación
# VISUALIZATION_MAX_CODE_LENGTH=5000
# VISUALIZATION_ENABLE_TEMPLATE_FALLBACK=True

# Configuración visual
# VISUALIZATION_DEFAULT_TEMPLATE=plotly_white
# VISUALIZATION_DEFAULT_WIDTH=800
# VISUALIZATION_DEFAULT_HEIGHT=600

# Objetivos de rendimiento (en milisegundos)
# VISUALIZATION_TARGET_END_TO_END_MS=5000
# VISUALIZATION_TARGET_TEMPLATE_MS=1000
# VISUALIZATION_TARGET_LLM_MS=4000

# Configuración de caché
# VISUALIZATION_TEMPLATE_CACHE_SIZE=100
# VISUALIZATION_VALIDATION_CACHE_SIZE=50
# VISUALIZATION_ENABLE_CACHING=True

# Configuración de preprocesamiento
# VISUALIZATION_NULL_THRESHOLD=0.5

# Paleta de colores médicos (separados por comas)
# Colores optimizados para visualizaciones médicas:
# - Azul médico (#2E86AB): Datos principales
# - Verde clínico (#06A77D): Valores normales
# - Rojo alerta (#D62828): Valores críticos
# - Naranja advertencia (#F77F00): Valores de advertencia
# - Púrpura (#8338EC): Datos secundarios
# - Azul cielo (#3A86FF): Datos complementarios
# VISUALIZATION_COLOR_PALETTE=#2E86AB,#06A77D,#D62828,#F77F00,#8338EC,#3A86FF

# ================================
# CONFIGURACIÓN DE CHAT UNIFICADO (Opcional)
# ================================
# El Chat Unificado integra acceso a MIMIC-IV-ED y documentos RAG
# en una sola interfaz inteligente con selección automática de herramientas

# Gestión de Contexto
# UNIFIED_CHAT_MAX_CONTEXT_MESSAGES=10

# Configuración de Caché
# UNIFIED_CHAT_ENABLE_CACHING=True
# UNIFIED_CHAT_CACHE_TTL=300

# Configuración de LLM
# UNIFIED_CHAT_MAX_TOKENS=4000
# UNIFIED_CHAT_TEMPERATURE=0.1

# Características
# UNIFIED_CHAT_ENABLE_VISUALIZATIONS=True
# UNIFIED_CHAT_ENABLE_DOCUMENT_UPLOAD=True

# Rendimiento
# UNIFIED_CHAT_QUERY_TIMEOUT=30
# UNIFIED_CHAT_RAG_TIMEOUT=15

# Formato de Respuesta
# UNIFIED_CHAT_RESPONSE_LANGUAGE=es
# UNIFIED_CHAT_INCLUDE_SOURCES=True

# Herramientas
# UNIFIED_CHAT_ENABLE_DATABASE_TOOL=True
# UNIFIED_CHAT_ENABLE_RAG_TOOL=True
# UNIFIED_CHAT_ENABLE_VISUALIZATION_TOOL=True

# Seguridad y Validación
# UNIFIED_CHAT_ENABLE_QUERY_VALIDATION=True
# UNIFIED_CHAT_MAX_QUERY_COMPLEXITY=5
# UNIFIED_CHAT_MAX_RESULT_ROWS=1000

# Reintentos
# UNIFIED_CHAT_MAX_RETRIES=3
# UNIFIED_CHAT_RETRY_DELAY=2.0

# Logging y Monitoreo
# UNIFIED_CHAT_ENABLE_PERFORMANCE_TRACKING=True
# UNIFIED_CHAT_LOG_TOOL_USAGE=True

# Gestión de Sesión
# UNIFIED_CHAT_SESSION_TIMEOUT=60
# UNIFIED_CHAT_SAVE_HISTORY=True

# ================================
# CONFIGURACIÓN DE AGENTE MÉDICO (Opcional)
# ================================

# Configuración del agente CrewAI
# AGENT_ROLE=Medical Data Assistant
# AGENT_GOAL=Provide accurate medical information and visualizations from MIMIC-IV-ED data
# AGENT_BACKSTORY=Expert medical data analyst with access to emergency department records
# AGENT_MAX_ITERATIONS=10
# AGENT_ALLOW_DELEGATION=False
# AGENT_VERBOSE=True

# Configuración de consultas de base de datos
# QUERY_TIMEOUT_SECONDS=30
# MAX_RESULT_ROWS=1000
# CONNECTION_RETRY_ATTEMPTS=3
# CONNECTION_RETRY_DELAY=1.0

# Configuración de visualizaciones
# VISUALIZATION_DPI=150
# VISUALIZATION_TIMEOUT_SECONDS=15
# MAX_CHART_DATA_POINTS=5000
# CHART_WIDTH=800
# CHART_HEIGHT=600
# CHART_FORMAT=png

# Modelos LLM para el agente (fallback chain)
# PRIMARY_MODEL=claude-haiku-4-5-20251001
# SECONDARY_MODEL=claude-sonnet-4-5-20250929
# TERTIARY_MODEL=claude-opus-4-20250514
# FALLBACK_MODEL=claude-haiku-4-5-20251001

# Configuración de API y reintentos
# API_RETRY_ATTEMPTS=3
# API_RETRY_DELAY=2.0
# API_TIMEOUT_SECONDS=60

# Configuración de monitoreo de salud del agente
# HEALTH_CHECK_INTERVAL=300
# MAX_MEMORY_USAGE_MB=512

# Configuración de seguridad y validación
# ENABLE_QUERY_VALIDATION=True
# ALLOWED_SCHEMAS=mimic_ed

# ================================
# CONFIGURACIÓN DE SEGURIDAD (Opcional)
# ================================

# Clave de encriptación para datos sensibles
# ENCRYPTION_KEY=tu_clave_de_encriptacion_segura

# Configuración de sesiones
# SESSION_TIMEOUT_MINUTES=480
# MAX_FAILED_LOGINS=5

# ================================
# CONFIGURACIÓN DE TERCEROS (Opcional)
# ================================

# OpenAI API Key (para embeddings alternativos)
# OPENAI_API_KEY=tu_openai_api_key

# Configuración de email (para notificaciones)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=tu_email@gmail.com
# SMTP_PASSWORD=tu_password_de_aplicacion

# ================================
# INSTRUCCIONES DE CONFIGURACIÓN
# ================================

# 1. Copia este archivo como .env en la raíz del proyecto
# 2. Reemplaza los valores de ejemplo con tus credenciales reales
# 3. Las variables marcadas como (Requerido) son obligatorias
# 4. Las variables (Opcional) tienen valores por defecto en config.py
# 5. Nunca subas el archivo .env a control de versiones

# ================================
# OBTENER CREDENCIALES
# ================================

# ANTHROPIC API KEY:
# 1. Visita https://console.anthropic.com
# 2. Crea una cuenta o inicia sesión
# 3. Ve a "API Keys" en el dashboard
# 4. Crea una nueva API key
# 5. Copia la key y pégala arriba

# SUPABASE:
# 1. Visita https://supabase.com
# 2. Crea una cuenta o inicia sesión
# 3. Crea un nuevo proyecto
# 4. Ve a Settings > API
# 5. Copia la URL y la anon key
# 6. Ejecuta el SQL del README.md en el SQL Editor

# ================================
# VERIFICACIÓN DE CONFIGURACIÓN
# ================================

# Para verificar que todo está configurado correctamente:
# 1. Ejecuta: python -c "from config import validate_config; print(validate_config())"
# 2. Si hay errores, revisa las variables de entorno
# 3. Asegúrate de que todas las dependencias estén instaladas

